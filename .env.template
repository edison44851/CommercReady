# n8n image tag used by docker compose (stack-specific, not a native n8n env var)
N8N_VERSION=stable

# n8n configuration
# Usage: set true only when n8n is served over HTTPS to keep auth cookies secure
N8N_SECURE_COOKIE=false
# Usage: public URL of the n8n editor UI used for links and callbacks
N8N_EDITOR_BASE_URL=http://localhost:5678
# Usage: execution strategy; regular runs in main process, queue uses workers
EXECUTIONS_MODE=regular
# Usage: enable automatic deletion of old execution records
EXECUTIONS_DATA_PRUNE=true
# Usage: max age in hours before execution data becomes eligible for pruning
EXECUTIONS_DATA_MAX_AGE=12
# Usage: cap number of stored execution records regardless of age
EXECUTIONS_DATA_PRUNE_MAX_COUNT=200
# Usage: if true, failed executions are also removed by pruning
EXECUTIONS_DATA_PRUNE_RETRY_FAILED=false
# Usage: controls what execution data to persist on failed runs (all, none)
N8N_EXECUTIONS_DATA_SAVE_ON_ERROR=all
# Usage: controls what execution data to persist on successful runs (all, none)
N8N_EXECUTIONS_DATA_SAVE_ON_SUCCESS=none
# Usage: controls whether manually triggered runs keep execution payload data
N8N_EXECUTIONS_DATA_SAVE_MANUAL_EXECUTIONS=false
# Usage: allow installation and execution of n8n community nodes
N8N_COMMUNITY_PACKAGES_ENABLED=true

# External runners (security isolation)
# Usage: run code/tool tasks in isolated external task runners
N8N_RUNNERS_MODE=external
# Usage: shared secret between n8n and runners for runner authentication
N8N_RUNNERS_AUTH_TOKEN=your-runner-auth-token
# Usage: bind address for the task broker listener inside the n8n container
N8N_RUNNERS_BROKER_LISTEN_ADDRESS=0.0.0.0
# Usage: internal URL used by runners to reach n8n task broker
N8N_RUNNERS_TASK_BROKER_URI=http://n8n:5679
# Usage: Node.js max old-space-size (MB) for runner processes
N8N_RUNNERS_MAX_OLD_SPACE_SIZE=4096

# Security (tightened)
# Usage: restrict filesystem access available to read/write nodes and code nodes
N8N_RESTRICT_FILE_ACCESS_TO=/data/confidential
# Usage: limit incoming request payload size (MB) to reduce abuse risk
N8N_PAYLOAD_SIZE_MAX=50
# Usage: allowlist built-in Node modules for Code node imports
N8N_NODE_FUNCTION_ALLOW_BUILTIN=fs,path

# Execution logging compatibility aliases
# Usage: legacy/non-prefixed alias of N8N_EXECUTIONS_DATA_SAVE_ON_ERROR
EXECUTIONS_DATA_SAVE_ON_ERROR=all
# Usage: legacy/non-prefixed alias of N8N_EXECUTIONS_DATA_SAVE_ON_SUCCESS
EXECUTIONS_DATA_SAVE_ON_SUCCESS=none
# Usage: legacy/non-prefixed alias of N8N_EXECUTIONS_DATA_SAVE_MANUAL_EXECUTIONS
EXECUTIONS_DATA_SAVE_MANUAL_EXECUTIONS=false

# Timezone
# Usage: default timezone for cron/schedule behavior and UI date handling
GENERIC_TIMEZONE=Asia/Hong_Kong

# Presidio integration (stack-specific, used by your workflows/nodes)
# Usage: internal analyzer endpoint for PII detection requests
PRESIDIO_ANALYZER_URL=http://presidio-analyzer:3000
# Usage: internal anonymizer endpoint for redaction/anonymization requests
PRESIDIO_ANONYMIZER_URL=http://presidio-anonymizer:3000
